{
  "name": "spawn-rx",
  "version": "6.0.1",
  "description": "An Rx-version of child_process.spawn",
  "scripts": {
    "doc": "echo \"esdoc may not work correctly\" && esdoc -c ./esdoc.json",
    "compile": "tsgo -p ./tsconfig.json",
    "prepublishOnly": "bun run build",
    "check": "biome check",
    "fix": "biome check --write --unsafe .",
    "test": "bun test",
    "build": "bun run compile && bun run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anaisbetts/spawn-rx.git"
  },
  "keywords": [
    "spawn",
    "rx"
  ],
  "author": "Anaïs Betts <anais@anaisbetts.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/anaisbetts/spawn-rx/issues"
  },
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "homepage": "https://github.com/anaisbetts/spawn-rx",
  "dependencies": {
    "debug": "^4.4.3",
    "lru-cache": "^11.3.5",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260504.1",
    "babel-register": "^6.26.0",
    "esdoc": "^1.1.0",
    "esdoc-es7-plugin": "0.0.3",
    "esdoc-plugin-async-to-sync": "^0.5.0",
    "uuid": "14.0.0"
  }
}
